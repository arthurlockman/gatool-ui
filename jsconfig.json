{
    "compilerOptions": {
      "baseUrl": "./src",
      "checkJs": true,
      "jsx": "react-jsx",
      "target": "ES2020",
      "module": "commonjs",
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "allowSyntheticDefaultImports": true,
      "esModuleInterop": true
    },
    "exclude": [
      "node_modules"
    ]
  }