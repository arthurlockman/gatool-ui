# API base for the gatool backend (defaults to https://api.gatool.org/v3/).
# Use the local backend during development:
VITE_API_BASE=http://localhost:3001/v3/

# Optional: load Help from GitHub wiki markdown at runtime (needs network).
# Default is the bundled snapshot in public/help-docs.html.
# VITE_HELP_LIVE_WIKI=true
